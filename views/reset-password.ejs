<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>SYSTEM_ACCESS // RESET</title>
  <link href="https://fonts.googleapis.com/css2?family=Share+Tech+Mono&display=swap" rel="stylesheet">
  
  <style>
    :root {
      --bg-dark: #030303;
      --text-main: #f0f0f0;
      --text-muted: #555555;
      --border-color: #333333;
      --accent-glow: rgba(255, 255, 255, 0.05);
      --pure-white: #ffffff;
      --font-mono: 'Share Tech Mono', monospace;
    }

    * {
      box-sizing: border-box;
    }

    body {
      background-color: var(--bg-dark);
      color: var(--text-main);
      font-family: var(--font-mono);
      display: flex;
      justify-content: center;
      align-items: center;
      height: 100vh;
      margin: 0;
      overflow: hidden;
      /* Subtle schematic grid background */
      background-image: 
        linear-gradient(var(--accent-glow) 1px, transparent 1px),
        linear-gradient(90deg, var(--accent-glow) 1px, transparent 1px);
      background-size: 40px 40px;
      background-position: center center;
    }

    .form-container {
      position: relative;
      width: 100%;
      max-width: 460px;
      padding: 3rem 2.5rem;
      background: rgba(3, 3, 3, 0.75);
      backdrop-filter: blur(12px); /* The requested blur effect */
      -webkit-backdrop-filter: blur(12px);
      border: 1px solid var(--border-color);
      box-shadow: 0 20px 50px rgba(0, 0, 0, 0.5);
    }

    /* Tactical HUD Corners */
    .hud-bracket {
      position: absolute;
      width: 15px;
      height: 15px;
      border: 2px solid var(--text-muted);
      transition: border-color 0.3s ease;
    }
    .top-left { top: -1px; left: -1px; border-right: none; border-bottom: none; }
    .top-right { top: -1px; right: -1px; border-left: none; border-bottom: none; }
    .bottom-left { bottom: -1px; left: -1px; border-right: none; border-top: none; }
    .bottom-right { bottom: -1px; right: -1px; border-left: none; border-top: none; }

    .form-container:hover .hud-bracket {
      border-color: var(--pure-white);
    }

    header {
      display: flex;
      justify-content: space-between;
      font-size: 0.75rem;
      color: var(--text-muted);
      margin-bottom: 2.5rem;
      border-bottom: 1px solid var(--border-color);
      padding-bottom: 0.5rem;
      letter-spacing: 2px;
    }

    h2 {
      font-size: 1.4rem;
      font-weight: normal;
      letter-spacing: 3px;
      margin-top: 0;
      margin-bottom: 2.5rem;
      text-transform: uppercase;
      color: var(--pure-white);
    }

    .input-group {
      margin-bottom: 1.5rem;
      display: flex;
      flex-direction: column;
      position: relative;
    }

    .input-group label {
      font-size: 0.8rem;
      margin-bottom: 0.5rem;
      color: #888;
      letter-spacing: 1px;
      text-transform: uppercase;
    }

    .input-group input {
      background: transparent;
      border: 1px solid var(--border-color);
      color: var(--pure-white);
      font-family: var(--font-mono);
      padding: 1rem;
      font-size: 1rem;
      outline: none;
      border-radius: 0; /* Strict square brutalism */
      transition: all 0.2s ease;
      letter-spacing: 2px;
    }

    .input-group input::placeholder {
      color: #333;
    }

    /* Focus state showing a sharp, glowing indicator */
    .input-group input:focus {
      border-color: var(--pure-white);
      background: rgba(255, 255, 255, 0.03);
    }

    /* Straight line tracking elements */
    .tracking-line {
      position: absolute;
      left: -2.5rem;
      top: 50%;
      width: 1.5rem;
      height: 1px;
      background-color: var(--border-color);
      transition: background-color 0.2s;
    }
    .input-group input:focus + .tracking-line {
      background-color: var(--pure-white);
    }

    button {
      margin-top: 2rem;
      width: 100%;
      background: var(--text-muted);
      color: var(--bg-dark);
      font-family: var(--font-mono);
      border: none;
      padding: 1rem;
      font-size: 1rem;
      cursor: pointer;
      text-transform: uppercase;
      letter-spacing: 4px;
      font-weight: bold;
      transition: all 0.3s ease;
      position: relative;
      overflow: hidden;
    }

    button:hover {
      background: var(--pure-white);
      box-shadow: 0 0 15px rgba(255, 255, 255, 0.2);
    }
  </style>
</head>
<body>

  <div class="form-container">
    <div class="hud-bracket top-left"></div>
    <div class="hud-bracket top-right"></div>
    <div class="hud-bracket bottom-left"></div>
    <div class="hud-bracket bottom-right"></div>

    <header>
      <span>SEQ: 001</span>
      <span>STATUS: AWAITING_KEY</span>
    </header>

    <h2>RESET_PASSWORD</h2>

    <form action="/api/auth/reset-password/<%= token %>" method="POST">
      
      <div class="input-group">
        <label for="password">> NEW_CREDENTIAL</label>
        <input type="password" id="password" name="password" placeholder="[ ENTER DATA ]" required />
        <div class="tracking-line"></div>
      </div>

      <div class="input-group">
        <label for="confirmPassword">> VERIFY_CREDENTIAL</label>
        <input type="password" id="confirmPassword" name="confirmPassword" placeholder="[ CONFIRM DATA ]" required />
        <div class="tracking-line"></div>
      </div>

      <button type="submit">EXECUTE_RESET</button>
      
    </form>
  </div>

  <script type="text/javascript">
    const passwordInput = document.querySelector("#password");
    const confirmPasswordInput = document.querySelector("#confirmPassword");
    const form = document.querySelector("form");

    const bufferToBase64 = (buffer) => {
      const bytes = new Uint8Array(buffer);
      let binary = "";
      for (let i = 0; i < bytes.byteLength; i++)
        binary += String.fromCharCode(bytes[i]);
      return window.btoa(binary);
    };
  
    const generateAndVaultKeys = async (password) => {
      const encoder = new TextEncoder();
      const keyPair = await window.crypto.subtle.generateKey(
        {
          name: "RSA-OAEP",
          modulusLength: 2048,
          publicExponent: new Uint8Array([1, 0, 1]),
          hash: "SHA-256",
        },
        true,
        ["encrypt", "decrypt"],
      );

      const pubKeyBuffer = await window.crypto.subtle.exportKey("spki", keyPair.publicKey);
      const privKeyBuffer = await window.crypto.subtle.exportKey("pkcs8", keyPair.privateKey);

      const passwordKeyMaterial = await window.crypto.subtle.importKey(
        "raw",
        encoder.encode(password),
        { name: "PBKDF2" },
        false,
        ["deriveBits", "deriveKey"],
      );

      const salt = window.crypto.getRandomValues(new Uint8Array(16));
      const aesKey = await window.crypto.subtle.deriveKey(
        {
          name: "PBKDF2",
          salt: salt,
          iterations: 100000,
          hash: "SHA-256",
        },
        passwordKeyMaterial,
        { name: "AES-GCM", length: 256 },
        false,
        ["encrypt"],
      );

      const iv = window.crypto.getRandomValues(new Uint8Array(12));
      const encryptedPrivKeyBuffer = await window.crypto.subtle.encrypt(
        { name: "AES-GCM", iv: iv },
        aesKey,
        privKeyBuffer,
      );

      return {
        publicKey: bufferToBase64(pubKeyBuffer),
        encryptedPrivateKey: bufferToBase64(encryptedPrivKeyBuffer),
        keySalt: bufferToBase64(salt),
        keyIv: bufferToBase64(iv),
      };
    };

    form.addEventListener("submit", async (e) => {
      e.preventDefault();
      
      const password = passwordInput.value;
      const confirmPassword = confirmPasswordInput.value;

      if(password !== confirmPassword) {
        alert("Passwords do not match");
        return;
      }

      try {
        const btn = form.querySelector("button");
        btn.innerText = "GENERATING_KEYS...";
        btn.disabled = true;

        const keys = await generateAndVaultKeys(password);
        
        const response = await fetch(form.action, {
          method: "POST",
          headers: {
            "Content-Type": "application/json"
          },
          body: JSON.stringify({
            ...keys,
            password,
            confirmPassword
          })
        });
      } catch (err) {
        console.error(err);
        alert("An error occurred during reset.");
      }
    });
  </script>

</body>
</html>
